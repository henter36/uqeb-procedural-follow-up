{
  "ScannerBridge": {
    "Port": 5055,
    "Version": "0.1.0",
    "Provider": "Auto",
    "AllowMockFallback": false,
    "TempTtlMinutes": 10,
    "MaxFileSizeBytes": 26214400,
    "PreviewMaxWidth": 420
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost",
      "http://127.0.0.1",
      "http://[::1]"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
