{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=UqebDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "YOUR_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "UqebApi",
    "Audience": "UqebClient",
    "ExpireMinutes": 480
  },
  "AllowedOrigins": [
    "https://your-frontend-domain.example"
  ],
  "FileStorage": {
    "Path": "C:\\Uqeb\\Attachments"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HealthChecks": {
    "DatabaseTimeoutSeconds": 5
  },
  "FeatureFlags": {
    "InstitutionalReports": true
  },
  "DatabaseStartup": {
    "RunMigrationsOnStartup": false,
    "RunReferenceSeedOnStartup": false,
    "RunDefaultUsersSeedOnStartup": false,
    "RunDemoSeedOnStartup": false
  },
  "FollowUpLetters": {
    "DisplayTimeZoneId": "Arab Standard Time",
    "DefaultDaysSinceLastFollowUp": 10,
    "MinDaysSinceLastFollowUp": 1,
    "MaxDaysSinceLastFollowUp": 365,
    "ExcludeRecentlyPrintedByDefault": true,
    "PrintedLetterExclusionDays": 7,
    "MinPrintedLetterExclusionDays": 1,
    "MaxPrintedLetterExclusionDays": 90,
    "DefaultBatchPrintSize": 25,
    "MaxBatchPrintSize": 50,
    "AbsoluteMaxBatchPrintSize": 100,
    "MaxEstimatedPagesPerPart": 100,
    "MaxConcurrentPrintJobs": 2,
    "MaxConcurrentJobsPerUser": 1,
    "MaxOutstandingUnprintedJobs": 10,
    "MaxTemplateContentLength": 50000,
    "JobLeaseSeconds": 120,
    "JobRetryCount": 3,
    "JobExpirationHours": 24,
    "NotificationPollIntervalSeconds": 45,
    "MaxLettersPerPrintView": 100,
    "MaxBodyLinesPerLetter": 500,
    "MaxBodyCharactersPerLetter": 20000
  },
  "Reporting": {
    "MaxPreviewDetailRows": 500,
    "MaxPdfDetailRows": 5000,
    "MaxPdfDetailRowsPerPart": 5000,
    "MaxDocxDetailRows": 20000,
    "MaxXlsxDetailRows": 100000,
    "MaxHtmlDetailRows": 20000,
    "MaxPdfParts": 20,
    "MaxExportFileSizeMb": 100,
    "MaxExportDurationSeconds": 120,
    "MaxConcurrentReportBuilds": 4,
    "MaxConcurrentPdfExports": 2,
    "MaxConcurrentNonPdfExports": 4,
    "ExportConcurrencyWaitSeconds": 30,
    "MinFreeTempSpaceMb": 512,
    "MaxTempBytesPerExport": 500000000,
    "MaxTotalTempBytes": 2000000000,
    "TempFileMaxAgeMinutes": 120,
    "ReadinessCacheSeconds": 45,
    "ChromiumProbeTimeoutSeconds": 15
  },
  "ReportingRollout": {
    "EnforcementMode": "ObserveOnly",
    "EnabledForRoles": [],
    "EnabledForUserIds": [],
    "EnabledForDepartments": [],
    "Percentage": 0,
    "EmergencyDisable": false
  }
}
