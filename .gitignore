# Secrets / local config
backend/Uqeb.Api/appsettings.json
appsettings.Development.json
appsettings.Local.json

# Generated reports / exports
tmp_report.*
*.pdf
*.xlsx

# Keep example config
!backend/Uqeb.Api/appsettings.example.json

# Test results
TestResults/
coverage/

# Reporting acceptance benchmark JSON (CI artifacts)
artifacts/reporting-acceptance/*.json
artifacts/performance-baseline/*
!artifacts/performance-baseline/.gitkeep

# Visual regression test artifacts (actual screenshots written during test runs)
artifacts/test-results/

# Build-script output (build-production-package.ps1 / dotnet publish / EF migrations)
artifacts/publish-api/
artifacts/production/
artifacts/production-staging-temp/
artifacts/migrations-idempotent.sql

# Windows drive-letter directories accidentally created on macOS/Linux by FileStorage:Path init
# e.g. C:\Uqeb\attachments becomes a literal dir name that breaks MSBuild glob expansion
backend/Uqeb.Api/[A-Za-z]:\*/
